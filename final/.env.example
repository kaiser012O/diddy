# ─────────────────────────────────────────────────────────────────────────
# .env.example
#
# انسخ هذا الملف باسم .env (بدون .example) واملأ القيم الحقيقية.
# .env لا يُرفع أبداً لأي مكان عام — فيه بيانات سرّية.
#
# الطريقة: cp .env.example .env    ثم عدّل .env بالقيم الحقيقية
# ─────────────────────────────────────────────────────────────────────────

# ── مطلوب دائماً — بدونها لن يعمل أي endpoint يلمس قاعدة البيانات ──────────
# من: Firebase Console → Project Settings → Service Accounts →
#      "Generate new private key" (يحمّل ملف JSON فيه هذي القيم)
FIREBASE_PROJECT_ID=mid6-59c85
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── منفذ السيرفر المحلي (اختياري، الافتراضي 3000) ──────────────────────────
PORT=3000

# ── اختياري — بدونها الميزات دي فقط تكون معطّلة بدون ما تكسر باقي الموقع ──

# مفتاح Gemini AI (لميزة "توليد وصف العيادة بالذكاء الاصطناعي" في لوحة الطبيب)
# من: https://aistudio.google.com
GEMINI_API_KEY=

# بيانات Twilio لإرسال إشعارات واتساب (حجز جديد + طلب تقييم)
# من: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# سرّ عشوائي (16+ حرف) لحماية مسار الـ cron اليومي — اختره بنفسك، أي نص عشوائي
# لو تركته فارغاً، الـ cron التلقائي (طلبات التقييم اليومية) يبقى معطّل تلقائياً
CRON_SECRET=

# رابط موقعك الحقيقي (يُستخدم داخل رسالة واتساب طلب التقييم كرابط مباشر)
# محلياً اتركه على القيمة الافتراضية دي
SITE_URL=http://localhost:3000

# نطاق CORS المسموح — محلياً اتركه فارغاً (يسمح بكل شيء تلقائياً أثناء التطوير)
ALLOWED_ORIGIN=
